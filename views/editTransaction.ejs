<!DOCTYPE html>
<html>
<head>
    <title>Edit Transaction</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container mt-4">

<h2>Chỉnh sửa giao dịch</h2>

<form action="/transactions/edit/<%= transaction.id %>" method="POST">

    <div class="mb-3">

        <label>Danh mục</label>

        <select name="category_id" class="form-control" required>
            <% categories.forEach(category => { %>

                <option value="<%= category.id %>">
                    <% if (category.name === 'Food') { %>
                        Ăn uống
                    <% } else if (category.name === 'Entertainment') { %>
                        Giải trí
                    <% } else if (category.name === 'Transport') { %>
                        Di chuyển
                    <% } else if (category.name === 'Shopping') { %>
                        Mua sắm
                    <% } else { %>
                        Khác
                    <% } %>
                </option>

            <% }) %>
        </select>

    </div>

    <div class="mb-3">

        <label>Số tiền</label>

        <input
            type="number"
            name="amount"
            class="form-control"
            value="<%= transaction.amount %>">

    </div>

    <div class="mb-3">

        <label>Ghi chú</label>

        <input
            type="text"
            name="note"
            class="form-control"
            value="<%= transaction.note %>">

    </div>

    <div class="mb-3">

        <label>Ngày</label>

        <input
            type="date"
            name="transaction_date"
            class="form-control"
            value="<%= transaction.transaction_date.toISOString().split('T')[0] %>">

    </div>

    <button class="btn btn-primary">
        Cập nhật
    </button>

</form>

</body>
</html>