<!DOCTYPE html>
<html>
<head>
    <title>SpendWise - Quản lý ngân sách</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container mt-4">

<h2>Quản lý ngân sách</h2>

<a href="/" class="btn btn-secondary mb-3">
    ← Quay lại
</a>

<div class="card mb-4">
    <div class="card-body">

        <h5>Thêm danh mục mới</h5>

        <form action="/budgets/add-category" method="POST" class="row">

            <div class="col-md-3">
                <label class="form-label">Tên danh mục</label>

                <input
                    type="text"
                    name="name"
                    class="form-control"
                    placeholder="Nhập danh mục"
                    required>
            </div>

            <div class="col-md-3">
                <label class="form-label">Giới hạn chi tiêu</label>

                <input
                    type="number"
                    name="limit_amount"
                    class="form-control"
                    placeholder="Nhập giới hạn chi tiêu của bạnbạn"
                    required>
            </div>

            <div class="col-md-2">
                <label class="form-label">Tháng</label>

                <input
                    type="number"
                    name="month"
                    class="form-control"
                    value="6"
                    min="1"
                    max="12"
                    required>
            </div>

            <div class="col-md-2">
                <label class="form-label">Năm</label>

                <input
                    type="number"
                    name="year"
                    class="form-control"
                    value="2026"
                    required>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary w-100">
                    Thêm
                </button>
            </div>

        </form>

    </div>
</div>

<table class="table table-bordered table-hover">

    <thead class="table-light">
        <tr>
            <th>Danh mục</th>
            <th>Tháng</th>
            <th>Năm</th>
            <th>Giới hạn chi tiêu</th>
        </tr>
    </thead>

    <tbody>
        <% budgets.forEach(function(budget) { %>

            <tr>

                <td>
                    <% if (budget.category_name === 'Food') { %>
                        Ăn uống
                    <% } else if (budget.category_name === 'Entertainment') { %>
                        Giải trí
                    <% } else if (budget.category_name === 'Transport') { %>
                        Di chuyển
                    <% } else if (budget.category_name === 'Shopping') { %>
                        Mua sắm
                    <% } else { %>
                        <%= budget.category_name %>
                    <% } %>
                </td>

                <td>Tháng <%= budget.month %></td>

                <td><%= budget.year %></td>

                <td>
                    <form
                        action="/budgets/update/<%= budget.id %>"
                        method="POST"
                        class="budget-form">

                        <input
                            type="number"
                            name="limit_amount"
                            class="form-control budget-input"
                            value="<%= parseInt(budget.limit_amount) %>"
                            required>

                    </form>
                </td>

            </tr>

        <% }) %>
    </tbody>

</table>

<script>

document.querySelectorAll(".budget-input").forEach(input => {

    input.addEventListener("blur", () => {

        const form = input.closest("form");

        form.submit();
    });

    input.addEventListener("keydown", (event) => {

        if(event.key === "Enter") {

            event.preventDefault();

            const form = input.closest("form");

            form.submit();
        }
    });

});

</script>

</body>
</html>