<!DOCTYPE html>
<html>
<head>
    <title>Transactions</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container mt-4">

<h2>Quản lí giao dịch</h2>

<a href="/" class="btn btn-secondary mb-3">
    ← Quay lại
</a>

<form method="GET" action="/transactions" class="row mb-3">

    <div class="col-md-3">
        <label class="form-label">Danh mục</label>

        <select name="category" class="form-control">
            <option value="">Tất cả danh mục</option>

            <% categories.forEach(category => { %>
                <option
                    value="<%= category.name %>"
                    <%= selectedCategory === category.name ? 'selected' : '' %>>

                    <% if (category.name === 'Food') { %>
                        Ăn uống
                    <% } else if (category.name === 'Entertainment') { %>
                        Giải trí
                    <% } else if (category.name === 'Transport') { %>
                        Di chuyển
                    <% } else if (category.name === 'Shopping') { %>
                        Mua sắm
                    <% } else { %>
                        Khác
                    <% } %>
                </option>
            <% }) %>
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Tháng</label>

        <input
            type="month"
            name="month"
            class="form-control"
            value="<%= selectedMonth %>">
    </div>

    <div class="col-md-3">
        <label class="form-label">Sắp xếp</label>

        <select name="sort" class="form-control">
            <option value="date_desc" <%= selectedSort === 'date_desc' ? 'selected' : '' %>>
                Ngày gần nhất
            </option>

            <option value="date_asc" <%= selectedSort === 'date_asc' ? 'selected' : '' %>>
                Ngày xa nhất
            </option>

            <option value="amount_desc" <%= selectedSort === 'amount_desc' ? 'selected' : '' %>>
                Số tiền nhiều đến ít
            </option>

            <option value="amount_asc" <%= selectedSort === 'amount_asc' ? 'selected' : '' %>>
                Số tiền ít đến nhiều
            </option>
        </select>
    </div>

    <div class="col-md-3 d-flex align-items-end gap-2">
        <button class="btn btn-primary w-50">
            Lọc
        </button>

        <a href="/transactions" class="btn btn-secondary w-50">
            Đặt lại
        </a>
    </div>

</form>

<h5>Thêm giao dịch mới</h5>

<form action="/transactions/add" method="POST" class="mb-4">

    <div class="row">

        <div class="col-md-2">
            <label class="form-label">Danh mục</label>

            <select name="category_id" class="form-control" required>
                <% categories.forEach(category => { %>
                    <option value="<%= category.id %>">
                        <% if (category.name === 'Food') { %>
                            Ăn uống
                        <% } else if (category.name === 'Entertainment') { %>
                            Giải trí
                        <% } else if (category.name === 'Transport') { %>
                            Di chuyển
                        <% } else if (category.name === 'Shopping') { %>
                            Mua sắm
                        <% } else { %>
                            Khác
                        <% } %>
                    </option>
                <% }) %>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Số tiền</label>

            <input
                type="number"
                name="amount"
                class="form-control"
                placeholder="Nhập số tiền"
                required>
        </div>

        <div class="col-md-3">
            <label class="form-label">Ghi chú</label>

            <input
                type="text"
                name="note"
                class="form-control"
                placeholder="Nhập ghi chú">
        </div>

        <div class="col-md-2">
            <label class="form-label">Ngày giao dịch</label>

            <input
                type="date"
                name="transaction_date"
                class="form-control"
                required>
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-primary w-100">
                Thêm
            </button>
        </div>

    </div>

</form>

<div class="alert alert-info">
    <h5>Tổng chi tiêu: <%= Number(total).toLocaleString() %> VND</h5>
</div>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Danh mục</th>
            <th>Số tiền</th>
            <th>Ghi chú</th>
            <th>Ngày giao dịch</th>
            <th>Thao tác</th>
        </tr>
    </thead>

    <tbody>
        <% transactions.forEach(function(transaction) { %>
            <tr>

                <td>
                    <% if (transaction.category_name === 'Food') { %>
                        Ăn uống
                    <% } else if (transaction.category_name === 'Entertainment') { %>
                        Giải trí
                    <% } else if (transaction.category_name === 'Transport') { %>
                        Di chuyển
                    <% } else if (transaction.category_name === 'Shopping') { %>
                        Mua sắm
                    <% } else { %>
                        Khác
                    <% } %>
                </td>

                <td><%= Number(transaction.amount).toLocaleString() %> VND</td>

                <td><%= transaction.note %></td>

                <td><%= transaction.transaction_date.toISOString().split('T')[0] %></td>

                <td>
                    <a
                        href="/transactions/edit/<%= transaction.id %>"
                        class="btn btn-warning btn-sm">
                        Thay đổi
                    </a>

                    <a
                        href="/transactions/delete/<%= transaction.id %>"
                        class="btn btn-danger btn-sm"
                        onclick="return confirm('Delete this transaction?')">
                        Xóa
                    </a>
                </td>
            </tr>
        <% }) %>
    </tbody>

</table>

</body>
</html>