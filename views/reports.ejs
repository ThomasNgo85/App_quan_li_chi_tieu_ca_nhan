<!DOCTYPE html>
<html>
<head>
    <title>Reports</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container mt-4">

<h2>Báo cáo chi tiêu</h2>

<a href="/" class="btn btn-secondary mb-3">← Quay lại</a>

<div class="row">

    <div class="col-md-6">
        <div class="card">
            <div class="card-body">

                <h5>Báo cáo theo danh mục</h5>

                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Danh mục</th>
                            <th>Tổng chi tiêu</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% categoryReport.forEach(item => { %>
                            <tr>
                                <td>
                                    <% if (item.category_name === 'Food') { %>
                                        Ăn uống
                                    <% } else if (item.category_name === 'Entertainment') { %>
                                        Giải trí
                                    <% } else if (item.category_name === 'Transport') { %>
                                        Di chuyển
                                    <% } else if (item.category_name === 'Shopping') { %>
                                        Mua sắm
                                    <% } else { %>
                                        <%= item.category_name %>
                                    <% } %>
                                </td>
                                
                                <td><%= Number(item.total).toLocaleString() %> VND</td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>

            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-body">

                <h5>Báo cáo theo tháng</h5>

                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Tháng</th>
                            <th>Tổng chi tiêu</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% monthlyReport.forEach(item => { %>
                            <tr>
                                <td><%= item.month %></td>
                                <td><%= Number(item.total).toLocaleString() %> VND</td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>

            </div>
        </div>
    </div>

</div>

</body>
</html>